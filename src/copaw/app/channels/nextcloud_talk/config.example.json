{
  "channels": {
    "nextcloud_talk": {
      "enabled": true,
      "webhook_secret": "YOUR_SECRET_HERE (32 bytes hex string)",
      "webhook_host": "0.0.0.0",
      "webhook_port": 8765,
      "webhook_path": "/webhook/nextcloud_talk",
      "bot_prefix": "[BOT] "
    }
  }
}

# 说明:
#
# 1. webhook_secret: 与 OCC 命令中的 --secret 参数相同
#    生成方法: openssl rand -hex 32
#
# 2. webhook_host: Webhook 服务器监听地址
#    - 0.0.0.0: 监听所有网络接口（推荐）
#    - 127.0.0.1: 只监听本地（安全，但需要反向代理）
#
# 3. webhook_port: Webhook 服务器端口（默认 8765）
#
# 4. webhook_path: Webhook URL 路径（默认 /webhook/nextcloud_talk）
#
# 5. bot_prefix: Bot 消息前缀（例如 [BOT] 或 🤖）
#
#
# 完整配置示例:
#
# {
#   "channels": {
#     "console": { "enabled": true },
#     "nextcloud_talk": {
#       "enabled": true,
#       "webhook_secret": "abc123def456...",
#       "webhook_host": "0.0.0.0",
#       "webhook_port": 8765,
#       "webhook_path": "/webhook/nextcloud_talk",
#       "bot_prefix": "[BOT] "
#     }
#   },
#   "agents": {
#     "language": "zh"
#   },
#   "show_tool_details": true
# }
